    },
    {
      "clientId": "rag-extension",
      "name": "Браузерное расширение rag_app",
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["https://mhjdfiggibjmaiomlggloepafgphgdpa.chromiumapp.org/*"],
      "webOrigins": ["+"],
      "attributes": { "pkce.code.challenge.method": "S256" }
    }
  ],
