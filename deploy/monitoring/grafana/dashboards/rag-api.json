{
  "uid": "rag-api",
  "title": "rag_app — API",
  "tags": ["rag"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Запросы/с по эндпоинтам",
      "datasource": { "type": "prometheus", "uid": "rag-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "rag-prometheus" },
          "expr": "sum by (handler) (rate(http_requests_total[5m]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Ошибки 5xx/с",
      "datasource": { "type": "prometheus", "uid": "rag-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "rag-prometheus" },
          "expr": "sum by (handler) (rate(http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Латентность p95, с",
      "datasource": { "type": "prometheus", "uid": "rag-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "rag-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Запросы/с (всего)",
      "datasource": { "type": "prometheus", "uid": "rag-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "rag-prometheus" },
          "expr": "sum(rate(http_requests_total[5m]))",
          "legendFormat": "rps"
        }
      ]
    }
  ]
}
