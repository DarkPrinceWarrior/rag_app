# Скопировать в .env и поправить под окружение. Все переменные приложения — с префиксом RAG_.

# PostgreSQL (compose поднимает на 127.0.0.1:5433)
RAG_DATABASE_URL=postgresql+asyncpg://rag:rag-pg-2026@127.0.0.1:5433/rag_app
RAG_PG_USER=rag
RAG_PG_PASSWORD=rag-pg-2026
RAG_PG_DB=rag_app

# Redis
RAG_REDIS_HOST=127.0.0.1
RAG_REDIS_PORT=6379

# MinIO
RAG_S3_ENDPOINT=127.0.0.1:9000
RAG_S3_ACCESS_KEY=rag-minio
RAG_S3_SECRET_KEY=rag-minio-secret-2026

# vLLM (Qwen3-32B-AWQ, GPU0, порт 8001)
RAG_LLM_BASE_URL=http://127.0.0.1:8001/v1
RAG_LLM_MODEL=qwen3-32b-awq
RAG_TRANSLATE_CONCURRENCY=12

# MinerU: GPU2 — контур парсинга (roadmap § 4.3)
RAG_MINERU_DEVICE=cuda:2
